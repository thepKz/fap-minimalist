{
  "manifest_version": 3,
  "name": "FAP Minimal Skin",
  "version": "1.17.5",
  "description": "Minimal theme for FPT Academic Portal. Saves theme locally only. No personal data is transmitted.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "FAP Minimal Skin",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": [
        "https://fap.fpt.edu.vn/*"
      ],
      "run_at": "document_idle",
      "css": ["styles/fap-minimal.css"],
      "js": ["scripts/content.js", "scripts/transcript-gpa.js"]
    }
  ]
}
